{
  "name": "@voltcast/sdk",
  "version": "0.2.0",
  "description": "Official TypeScript SDK for the Voltcast API \u2014 15-minute European power prices, probabilistic price forecasts scored publicly every day, station-exact temperature distributions for weather markets, renewables, imbalance and grid data.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-strip-types test/client.test.ts"
  },
  "keywords": [
    "electricity",
    "prices",
    "epex",
    "entsoe",
    "day-ahead",
    "intraday",
    "forecast",
    "energy",
    "api",
    "power-market",
    "temperature",
    "weather-markets",
    "prediction-markets",
    "degree-days",
    "renewables",
    "imbalance",
    "europe"
  ],
  "license": "MIT",
  "homepage": "https://voltcast.com/docs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Voltcast-com/sdk.git",
    "directory": "typescript"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}